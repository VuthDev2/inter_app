{"name":"QuickVoice","slug":"quickvoice-mobile","version":"0.1.0","orientation":"portrait","icon":"./assets/logo.png","userInterfaceStyle":"light","scheme":"quickvoice","assetBundlePatterns":["**/*"],"ios":{"supportsTablet":true,"bundleIdentifier":"com.anonymous.quickvoicemobile"},"android":{"adaptiveIcon":{"foregroundImage":"./assets/logo.png","backgroundColor":"#0F766E"},"permissions":["android.permission.RECORD_AUDIO","android.permission.MODIFY_AUDIO_SETTINGS","android.permission.FOREGROUND_SERVICE","android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"],"package":"com.anonymous.quickvoicemobile"},"extra":{},"web":{"favicon":"./assets/logo.png","bundler":"metro"},"plugins":[["expo-audio",{"microphonePermission":"Allow QuickVoice to access the microphone for real-time interpretation."}]],"sdkVersion":"57.0.0","platforms":["ios","android","web"]}