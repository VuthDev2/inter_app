{
  "expo": {
    "name": "QuickVoice",
    "slug": "quickvoice-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/logo-l.png",
    "userInterfaceStyle": "light",
    "scheme": "quickvoice",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.quickvoicemobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-l.png",
        "backgroundColor": "#0F766E"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.quickvoicemobile"
    },
    "extra": {},
    "web": {
      "favicon": "./assets/logo-l.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow QuickVoice to access the microphone for real-time interpretation."
        }
      ],
      "expo-status-bar",
      "expo-web-browser"
    ]
  }
}
